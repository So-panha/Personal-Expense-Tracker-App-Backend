generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int                    @id @default(autoincrement())
  username              String                 @unique(map: "ix_users_username") @db.VarChar
  email                 String                 @unique(map: "ix_users_email") @db.VarChar
  hashed_password       String?                @db.VarChar
  full_name             String?                @db.VarChar
  location              String?                @db.VarChar
  avatar_url            String?                @db.VarChar
  role                  role
  status                userstatus
  failed_login_attempts Int
  is_deleted            Boolean
  consultation_history  consultation_history[]
  payment_methods       payment_methods[]
  user_preferences      user_preferences?

  @@index([id], map: "ix_users_id")
  @@map("users")
}

model consultation_history {
  id        Int      @id @default(autoincrement())
  user_id   Int
  title     String   @db.VarChar
  text      String   @db.VarChar
  tags      Json     @default("[]")
  icon      String   @db.VarChar
  timestamp DateTime @db.Timestamptz(6)
  users     User     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_consultation_history_id")
  @@index([user_id], map: "ix_consultation_history_user_id")
}

model payment_methods {
  id          Int     @id @default(autoincrement())
  user_id     Int
  card_type   String  @db.VarChar
  last4       String  @db.VarChar(4)
  expiry      String  @db.VarChar(5)
  is_default  Boolean
  bg_gradient String? @db.VarChar
  users       User    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_payment_methods_id")
  @@index([user_id], map: "ix_payment_methods_user_id")
}

model user_preferences {
  id                Int     @id @default(autoincrement())
  user_id           Int     @unique(map: "ix_user_preferences_user_id")
  dark_mode         Boolean
  compact_view      Boolean
  reduce_animations Boolean
  push_alerts       Boolean
  storm_warning     Boolean
  location_services Boolean
  users             User    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([id], map: "ix_user_preferences_id")
}

enum role {
  ADMIN
  USER
}

enum userstatus {
  ACTIVE
  INACTIVE
  LOCKED
}
