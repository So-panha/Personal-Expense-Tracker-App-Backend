# ─────────────────────────────────────────────────────────
# Environment Variables — copy to Render's "Environment" tab
# Do NOT commit real secrets. This file is safe to commit.
# ─────────────────────────────────────────────────────────

# PostgreSQL connection string (from Neon / Render Postgres / Supabase)
# For Render internal DB use the Internal Database URL shown in the DB service
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/expense_tracker?sslmode=require"

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=production

# SMTP — Gmail App Password recommended (2FA must be on)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# CORS whitelist — comma-separated origins (leave empty to allow all)
# Example: https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=
